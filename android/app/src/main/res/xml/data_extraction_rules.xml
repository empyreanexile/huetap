<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules (Android 12+). Per SPEC §6.10:
    - Cloud backup: include files/huetap.db, exclude files/no_backup/.
    - Device-to-device transfer: include files/huetap.db, exclude files/no_backup/.

  Both sections carry the same include/exclude set — semantically identical to
  backup_rules.xml — so the policy stays consistent across auto-backup and D2D
  transfers as the targetSdk is bumped over time.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="huetap.db"/>
        <exclude domain="file" path="no_backup/"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="huetap.db"/>
        <exclude domain="file" path="no_backup/"/>
    </device-transfer>
</data-extraction-rules>
